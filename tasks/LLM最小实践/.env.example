# 链配置
# 可选值: sepolia (默认) | mainnet
CHAIN=sepolia

# RPC 节点 URL（可选，有默认值）
# RPC_URL=https://sepolia.drpc.org

# 区块浏览器 API Key (Etherscan)
# 用于获取已验证合约的 ABI
# 注册地址: https://etherscan.io/register
BLOCK_EXPLORER_API_KEY=your_etherscan_api_key_here

# LLM API 配置（必填）
# 支持任何 OpenAI-compatible API
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
